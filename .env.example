# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bazos
# Single URL: BAZOS_SEARCH_URL
# Or multiple comma-separated URLs: BAZOS_SEARCH_URLS=https://...rss.php?... , https://...rss.php?...
# Examples:
# - Xiaomi category on bazos.sk (cat=451): https://www.bazos.sk/rss.php?rub=mo&cat=451
# - Mobil (mobile-optimized) host example: https://mobil.bazos.sk/rss.php?rub=mo&cat=451
# - General 'mobile' category (all brands): https://www.bazos.sk/rss.php?rub=mo
BAZOS_SEARCH_URL=
BAZOS_SEARCH_URLS=
# AI
AI_PROVIDER=
LOCAL_AI_URL=
# Poll interval in seconds
CHECK_INTERVAL=
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Legacy fallback (optional): set true to enable debug logs when LOG_LEVEL is unset
DEBUG=
POSTMARKETOS_MODELS_FILE=
