# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Bazos
# Single URL: BAZOS_SEARCH_URL
# Or multiple comma-separated URLs: BAZOS_SEARCH_URLS=https://...rss.php?... , https://...rss.php?...
# Examples:
# - General 'mobile' category (all brands): https://www.bazos.sk/rss.php?rub=mo
# - Xiaomi category on bazos.sk (cat=451): https://www.bazos.sk/rss.php?rub=mo&cat=451
# - Xiaomi category on bazos.cz (cat=455): https://www.bazos.cz/rss.php?rub=mo&cat=455
# BAZOS_SEARCH_URL=
BAZOS_SEARCH_URLS=https://www.bazos.sk/rss.php?rub=mo&cat=451,https://www.bazos.sk/rss.php?rub=mo&cat=436,https://www.bazos.sk/rss.php?rub=mo&cat=304,https://www.bazos.sk/rss.php?rub=mo&cat=307,https://www.bazos.cz/rss.php?rub=mo&cat=455,https://www.bazos.cz/rss.php?rub=mo&cat=440,https://www.bazos.cz/rss.php?rub=mo&cat=346,https://www.bazos.cz/rss.php?rub=mo&cat=349
# Poll interval in seconds
CHECK_INTERVAL=
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# PostmarketOS models file
POSTMARKETOS_MODELS_FILE=data/postmarketos_models.json
# Minimum listing price in EUR
MIN_PRICE_EUR=10
# Maximum listing price in EUR
MAX_PRICE_EUR=51